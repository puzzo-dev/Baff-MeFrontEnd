
{
  "name": "BAFF-ME E-commerce",
  "version": "1.0.0",
  "techStack": {
    "frontend": {
      "framework": "Next.js",
      "language": "TypeScript",
      "styling": "Tailwind CSS",
      "stateManagement": "Zustand",
      "routing": "Next.js App Router",
      "dataFetching": "Next.js Server Components"
    },
    "backend": {
      "framework": "Next.js API Routes",
      "language": "TypeScript",
      "runtime": "Node.js"
    }
  },
  "theme": {
    "colors": {
      "primary": "hsl(var(--primary))",
      "background": {
        "light": "#FFFFFF",
        "dark": "#111111"
      },
      "text": {
        "light": "#111111",
        "dark": "#FFFFFF"
      },
      "accent": "hsl(var(--accent))"
    },
    "typography": {
      "fonts": {
        "primary": "Inter",
        "logo": "Orbitron",
        "display": "Bebas Neue"
      }
    },
    "components": {
      "navbar": {
        "height": "64px",
        "background": {
          "default": "bg-white/90 dark:bg-[#111111]/90",
          "scrolled": "bg-white/95 dark:bg-[#111111]/95"
        }
      },
      "buttons": {
        "primary": "bg-primary text-white",
        "secondary": "bg-accent text-accent-foreground"
      }
    },
    "transitions": {
      "default": "transition-all duration-300",
      "fast": "transition-all duration-150"
    }
  },
  "features": {
    "darkMode": true,
    "autoTheme": true,
    "responsiveDesign": true,
    "animations": "Framer Motion"
  }
}
